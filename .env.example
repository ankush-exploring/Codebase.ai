# Server
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codebase_ai

# Redis (optional — caching disabled when unavailable)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Qdrant (optional — in-memory fallback when unavailable)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# AI Provider: 'ollama' (FREE, local), 'groq' (FREE tier), 'openai' (paid)
AI_PROVIDER=ollama

# Ollama (FREE — runs locally): https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Groq (FREE tier): https://console.groq.com/keys
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (paid — only needed if AI_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-3.5-turbo

# GitHub (for private repo import)
GITHUB_TOKEN=

# Frontend
VITE_API_URL=http://localhost:3001

# Logging
LOG_LEVEL=debug
