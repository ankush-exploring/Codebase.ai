# Server
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codebase_ai

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Qdrant (Vector Database)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# AI Provider: 'openai' (paid/Ollama) or 'gemini' (FREE)
AI_PROVIDER=openai

# OpenAI / Ollama:
OPENAI_API_KEY=
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.2:1b

# Google Gemini (FREE): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# GitHub (for repo import in later phases)
GITHUB_TOKEN=

# Frontend
VITE_API_URL=http://localhost:3001

# Logging
LOG_LEVEL=debug
